@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <span class="user-greeting">@User.Identity?.Name</span>
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" style="display:inline;">
        <button type="submit" class="nav-link nav-btn">Logout</button>
    </form>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Register" class="nav-link">Register</a>
    <a asp-area="Identity" asp-page="/Account/Login" class="btn-accent">Login</a>
}
