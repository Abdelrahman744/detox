@model detox.Models.FocusBlock

@{
    ViewData["Title"] = "Log New Block";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Log New Block</h1>
        <p class="page-subtitle">Record a new focus session or restriction protocol</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-group">
            <label asp-for="ActivityRestricted" class="form-label">Activity Restricted</label>
            <input asp-for="ActivityRestricted" class="form-input" placeholder='e.g. Social Media, Sugar, Video Games' />
            <span asp-validation-for="ActivityRestricted" class="validation-msg"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Duration</label>
                <div style="display: flex; gap: 0.5rem;">
                    <input asp-for="DurationValue" class="form-input" type="number" step="any" min="0.1" placeholder="e.g. 2.5" style="flex: 1;" />
                    <select asp-for="DurationUnit" class="form-input" style="flex: 1;">
                        <option value="Seconds">Seconds</option>
                        <option value="Hours">Hours</option>
                        <option value="Days">Days</option>
                        <option value="Months">Months</option>
                    </select>
                </div>
                <span asp-validation-for="DurationValue" class="validation-msg"></span>
                <span asp-validation-for="DurationUnit" class="validation-msg"></span>
            </div>

            <div class="form-group">
                <label asp-for="Date" class="form-label">Date</label>
                <input asp-for="Date" class="form-input" type="date" />
                <span asp-validation-for="Date" class="validation-msg"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="SuccessStatus" class="form-label">Protocol Maintained?</label>
            <select asp-for="SuccessStatus" class="form-input">
                <option value="true">✓ Yes — Fast Maintained</option>
                <option value="false">✗ No — Fast Broken</option>
            </select>
            <span asp-validation-for="SuccessStatus" class="validation-msg"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reflection" class="form-label">Reflection Notes <span class="optional">(optional)</span></label>
            <textarea asp-for="Reflection" class="form-input form-textarea" rows="4" placeholder="How did it go? Any insights..."></textarea>
            <span asp-validation-for="Reflection" class="validation-msg"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save Block</button>
            <a asp-action="Index" class="btn-ghost">Cancel</a>
        </div>
    </form>
</div>
