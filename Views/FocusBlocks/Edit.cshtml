@model detox.Models.FocusBlock

@{
    ViewData["Title"] = "Edit Block";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Edit Block</h1>
        <p class="page-subtitle">Update focus session #@Model.Id</p>
    </div>
    <a asp-action="Index" class="btn-secondary" id="edit-back-btn">← Back to Archive</a>
</div>

<div class="form-card" id="edit-form-card">
    <form asp-action="Edit" method="post" id="edit-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-section-title">Session Details</div>

        <div class="form-group">
            <label asp-for="ActivityRestricted" class="form-label">
                <span class="form-icon">🚫</span> Activity Restricted
            </label>
            <input asp-for="ActivityRestricted" class="form-input" id="ActivityRestricted" />
            <span asp-validation-for="ActivityRestricted" class="validation-msg"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label"><span class="form-icon">⏱</span> Duration</label>
                <div class="duration-row">
                    <input asp-for="DurationValue" class="form-input" id="DurationValue"
                           type="number" step="any" min="0.1" />
                    <select asp-for="DurationUnit" class="form-input" id="DurationUnit">
                        <option value="Seconds">Seconds</option>
                        <option value="Minutes">Minutes</option>
                        <option value="Hours">Hours</option>
                        <option value="Days">Days</option>
                        <option value="Months">Months</option>
                    </select>
                </div>
                <span asp-validation-for="DurationValue" class="validation-msg"></span>
                <span asp-validation-for="DurationUnit" class="validation-msg"></span>
            </div>

            <div class="form-group">
                <label asp-for="Date" class="form-label"><span class="form-icon">📅</span> Date</label>
                <input asp-for="Date" class="form-input" id="Date" type="date" />
                <span asp-validation-for="Date" class="validation-msg"></span>
            </div>
        </div>

        <div class="form-section-title" style="margin-top: 0.5rem;">Outcome</div>

        <div class="form-group">
            <label asp-for="SuccessStatus" class="form-label">
                <span class="form-icon">🏆</span> Protocol Maintained?
            </label>
            <select asp-for="SuccessStatus" class="form-input" id="SuccessStatus">
                <option value="true">✓ Yes — Fast Maintained</option>
                <option value="false">✗ No — Fast Broken</option>
            </select>
            <span asp-validation-for="SuccessStatus" class="validation-msg"></span>
        </div>

        <div class="form-group">
            <label asp-for="Reflection" class="form-label">
                <span class="form-icon">💭</span> Reflection Notes
                <span class="optional">(optional)</span>
            </label>
            <textarea asp-for="Reflection" class="form-input form-textarea" id="Reflection" rows="4"></textarea>
            <span asp-validation-for="Reflection" class="validation-msg"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary" id="edit-submit-btn">Update Block</button>
            <a asp-action="Index" class="btn-ghost" id="edit-cancel-btn">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
