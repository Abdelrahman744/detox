@model IEnumerable<detox.Models.FocusBlock>

@{
    ViewData["Title"] = "The Archive";
}

<div class="page-header">
    <div>
        <h1 class="page-title">The Archive</h1>
        <p class="page-subtitle">@Model.Count() focus block@(Model.Count() == 1 ? "" : "s") logged</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="Analytics" class="btn-secondary" id="archive-analytics-btn">📊 Analytics</a>
        <a asp-action="Create" class="btn-primary" id="archive-log-btn">＋ Log Block</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state" id="empty-archive">
        <span class="empty-icon">📋</span>
        <h3>No blocks logged yet</h3>
        <p>Start logging your dopamine detox sessions to build your archive.</p>
        <a asp-action="Create" class="btn-primary" id="empty-log-btn">Log Your First Block</a>
    </div>
}
else
{
    <div class="table-wrapper" id="archive-table-wrapper">
        <table class="data-table" id="archive-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Activity Restricted</th>
                    <th>Duration</th>
                    <th>Status</th>
                    <th>Reflection</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="cell-date">@item.Date.ToString("MMM dd, yyyy")</td>
                        <td><span class="activity-badge">@item.ActivityRestricted</span></td>
                        <td class="cell-duration">@item.DurationValue @item.DurationUnit</td>
                        <td>
                            @if (item.SuccessStatus)
                            {
                                <span class="status-badge success">✓ Maintained</span>
                            }
                            else
                            {
                                <span class="status-badge failure">✗ Broken</span>
                            }
                        </td>
                        <td class="cell-reflection" title="@(item.Reflection ?? "")">@(item.Reflection ?? "—")</td>
                        <td class="cell-actions">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn edit">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="button" class="action-btn delete" onclick="openDeleteModal(this.closest('form'))">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<dialog id="deleteConfirmModal" class="custom-modal">
    <div class="modal-content">
        <h3>Delete Block?</h3>
        <p>Are you sure you want to delete this focus block? This action cannot be undone.</p>
        <div class="modal-actions">
            <button type="button" class="btn-secondary" onclick="closeDeleteModal()" id="modal-cancel-btn">Cancel</button>
            <button type="button" class="btn-primary danger" onclick="confirmDelete()" id="modal-confirm-btn">Delete</button>
        </div>
    </div>
</dialog>

@section Scripts {
    <script>
        const modal = document.getElementById('deleteConfirmModal');
        let formToSubmit = null;
        function openDeleteModal(formElement) { formToSubmit = formElement; modal.showModal(); }
        function closeDeleteModal() { modal.close(); formToSubmit = null; }
        function confirmDelete() { if (formToSubmit) formToSubmit.submit(); }
    </script>
}
