@page
@model LoginModel

@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-wrap">
    <div class="auth-card" id="login-card">

        <div class="auth-brand">
            <span class="brand-icon">◉</span>
            <span class="auth-brand-name">Detox Ledger</span>
        </div>

        <div class="auth-header">
            <h1 class="auth-title">Welcome back</h1>
            <p class="auth-subtitle">Sign in to your account to continue your journey</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

            <div class="form-group">
                <label asp-for="Input.Email" class="form-label">
                    <span class="form-icon">✉</span> Email address
                </label>
                <input asp-for="Input.Email" class="form-input" id="Input_Email"
                       autocomplete="username" aria-required="true"
                       placeholder="you@example.com" type="email" />
                <span asp-validation-for="Input.Email" class="validation-msg"></span>
            </div>

            <div class="form-group">
                <div class="auth-label-row">
                    <label asp-for="Input.Password" class="form-label">
                        <span class="form-icon">🔒</span> Password
                    </label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="auth-link-sm">Forgot password?</a>
                </div>
                <div class="password-field">
                    <input asp-for="Input.Password" class="form-input" id="Input_Password"
                           autocomplete="current-password" aria-required="true"
                           placeholder="Enter your password" type="password" />
                    <button type="button" class="password-toggle" onclick="togglePassword('Input_Password', this)" aria-label="Toggle password visibility">👁</button>
                </div>
                <span asp-validation-for="Input.Password" class="validation-msg"></span>
            </div>

            <div class="form-group auth-remember">
                <label class="remember-label">
                    <input class="form-check-input" asp-for="Input.RememberMe" id="Input_RememberMe" />
                    <span>Remember me for 30 days</span>
                </label>
            </div>

            <button id="login-submit" type="submit" class="btn-primary auth-submit">
                Sign In →
            </button>
        </form>

        <div class="auth-footer-links">
            <p>Don't have an account?
                <a id="register" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">
                    Create one free →
                </a>
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(id, btn) {
            const input = document.getElementById(id);
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            btn.textContent = isHidden ? '🙈' : '👁';
        }
    </script>
}
