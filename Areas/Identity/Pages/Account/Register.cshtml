@page
@model RegisterModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-wrap">
    <div class="auth-card" id="register-card">

        <div class="auth-brand">
            <span class="brand-icon">◉</span>
            <span class="auth-brand-name">Detox Ledger</span>
        </div>

        <div class="auth-header">
            <h1 class="auth-title">Start your journey</h1>
            <p class="auth-subtitle">Create a free account to track and conquer your detox sessions</p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

            <div class="form-group">
                <label asp-for="Input.Email" class="form-label">
                    <span class="form-icon">✉</span> Email address
                </label>
                <input asp-for="Input.Email" class="form-input" id="Input_Email"
                       autocomplete="username" aria-required="true"
                       placeholder="you@example.com" type="email" />
                <span asp-validation-for="Input.Email" class="validation-msg"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password" class="form-label">
                    <span class="form-icon">🔒</span> Password
                </label>
                <div class="password-field">
                    <input asp-for="Input.Password" class="form-input" id="Input_Password"
                           autocomplete="new-password" aria-required="true"
                           placeholder="At least 6 characters" type="password" />
                    <button type="button" class="password-toggle" onclick="togglePassword('Input_Password', this)" aria-label="Toggle password visibility">👁</button>
                </div>
                <span asp-validation-for="Input.Password" class="validation-msg"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.ConfirmPassword" class="form-label">
                    <span class="form-icon">✅</span> Confirm password
                </label>
                <div class="password-field">
                    <input asp-for="Input.ConfirmPassword" class="form-input" id="Input_ConfirmPassword"
                           autocomplete="new-password" aria-required="true"
                           placeholder="Repeat your password" type="password" />
                    <button type="button" class="password-toggle" onclick="togglePassword('Input_ConfirmPassword', this)" aria-label="Toggle confirm password visibility">👁</button>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="validation-msg"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn-primary auth-submit">
                Create Account →
            </button>
        </form>

        <div class="auth-footer-links">
            <p>Already have an account?
                <a id="login-link" asp-page="./Login" class="auth-link">
                    Sign in →
                </a>
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(id, btn) {
            const input = document.getElementById(id);
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            btn.textContent = isHidden ? '🙈' : '👁';
        }
    </script>
}
